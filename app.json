{
  "expo": {
    "name": "Kredi Hesaplama",
    "slug": "bankaci-kredi-hesaplama",
    "version": "2.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xewor.bankacikredihesaplama",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "6"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B6EF3"
      },
      "package": "com.xewor.bankacikredihesaplama",
      "versionCode": 8
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#F4FAFF",
          "imageWidth": 320,
          "ios": {
            "image": "./assets/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#F4FAFF",
            "enableFullScreenImage_legacy": true
          },
          "android": {
            "image": "./assets/icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#F4FAFF"
          }
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "f5c8092a-cb6e-4bbc-b316-aad23f8d0e87"
      }
    },
    "owner": "xewor"
  }
}
